# ── Application ──────────────────────────────────────────────────────────
APP_NAME=aiecommerce-agents
DEBUG=false

# ── Docker — Host Port Configuration ────────────────────────────────────
# Change these if another project already uses the default ports.
API_PORT=8000
POSTGRES_PORT=5432

# ── Database (Local Registry) ────────────────────────────────────────────
# PostgreSQL (Docker Compose — default):
DATABASE_URL=postgresql+asyncpg://orchestrator:orchestrator@db:5432/orchestrator
# SQLite (local dev without Docker):
# DATABASE_URL=sqlite+aiosqlite:///./local_registry.db

# ── PostgreSQL Credentials (Docker Compose) ──────────────────────────────
POSTGRES_USER=orchestrator
POSTGRES_PASSWORD=orchestrator
POSTGRES_DB=orchestrator

# ── AIEcommerce API ──────────────────────────────────────────────────────
AIECOMMERCE_API_URL=https://api.aiecommerce.example.com
AIECOMMERCE_API_KEY=your-aiecommerce-api-key-here

# ── MercadoLibre OAuth ───────────────────────────────────────────────────
MERCADOLIBRE_CLIENT_ID=your-mercadolibre-client-id
MERCADOLIBRE_CLIENT_SECRET=your-mercadolibre-client-secret
MERCADOLIBRE_REDIRECT_URI=https://localhost:8000/auth/callback

# ── OpenAI (LangChain / LangGraph) ──────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
